# ===== HYPERLIQUID CREDENTIALS =====
# Carteira principal (apenas para assinar transações)
WALLET_ADDRESS=your_wallet_address_here

# Chave privada da carteira principal
HYPERLIQUID_PRIVATE_KEY=your_private_key_here

# ⚠️ OBRIGATÓRIO: Subconta/Vault onde o bot irá operar
# O bot SEMPRE opera na subconta, nunca na carteira principal
HYPERLIQUID_SUBACCOUNT=your_vault_address_here

# ===== BINANCE CREDENTIALS (opcional, para dados históricos) =====
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_API_SECRET=your_binance_api_secret_here

# ===== DISCORD NOTIFICATIONS (opcional) =====
DISCORD_WEBHOOK_URL=your_discord_webhook_url_here

# ===== GOOGLE SHEETS (opcional) =====
# Nome da planilha no Google Sheets
GOOGLE_SHEET_NAME=Base_logs
